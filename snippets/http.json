{
  "Get request": {
    "prefix": "get",
    "body": [
      "GET ${1:https://example.com} HTTP/1.1",
      "Accept: application/json"
    ],
    "description": "Insert a basic GET request."
  },
  "Post request": {
    "prefix": "post",
    "body": [
      "POST ${1:https://example.com} HTTP/1.1",
      "Content-Type: application/json",
      "",
      "{",
      "  \"$2\": \"$3\"",
      "}"
    ],
    "description": "Insert a basic POST request with JSON body."
  },
  "Put request": {
    "prefix": "put",
    "body": [
      "PUT ${1:https://example.com} HTTP/1.1",
      "Content-Type: application/json",
      "",
      "{",
      "  \"$2\": \"$3\"",
      "}"
    ],
    "description": "Insert a basic PUT request with JSON body."
  },
  "Delete request": {
    "prefix": "delete",
    "body": [
      "DELETE ${1:https://example.com} HTTP/1.1",
      "Accept: application/json"
    ],
    "description": "Insert a basic DELETE request."
  },
  "Request separator": {
    "prefix": "sep",
    "body": [
      "### ${1:requestName}"
    ],
    "description": "Insert a request separator."
  },
  "Named request": {
    "prefix": "name",
    "body": [
      "# @name ${1:requestName}"
    ],
    "description": "Insert a JetBrains HTTP Client request name."
  },
  "File variable": {
    "prefix": "var",
    "body": [
      "@${1:variableName} = ${2:value}"
    ],
    "description": "Insert a file-scoped variable."
  },
  "Pre-request script": {
    "prefix": "prescript",
    "body": [
      "< {%",
      "  $1",
      "%}"
    ],
    "description": "Insert a pre-request script block."
  },
  "Response handler script": {
    "prefix": "postscript",
    "body": [
      "> {%",
      "  $1",
      "%}"
    ],
    "description": "Insert a response handler script block."
  },
  "Response redirect": {
    "prefix": "redirect",
    "body": [
      ">> ${1:./response.json}"
    ],
    "description": "Insert a response redirect target."
  },
  "Multipart form-data request": {
    "prefix": "multipart",
    "body": [
      "POST ${1:https://example.com/upload} HTTP/1.1",
      "Content-Type: multipart/form-data; boundary=WebAppBoundary",
      "",
      "--WebAppBoundary",
      "Content-Disposition: form-data; name=\"${2:fieldName}\"",
      "",
      "${3:fieldValue}",
      "--WebAppBoundary",
      "Content-Disposition: form-data; name=\"${4:fileField}\"; filename=\"${5:file-name.txt}\"",
      "",
      "< ${6:./relative/path/to/file.txt}",
      "--WebAppBoundary--"
    ],
    "description": "Insert a multipart/form-data request."
  }
}
