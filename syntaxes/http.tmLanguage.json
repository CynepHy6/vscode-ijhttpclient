{
    "scopeName": "source.http",
    "fileTypes": ["http"],
    "keyEquivalent": "^~H",
    "name": "http",
    "patterns": [
        {
            "include": "#pre-request-script"
        },
        {
            "include": "#response-handler-script"
        },
        {
            "include": "#request-name-delimiter"
        },
        {
            "include": "#metadata"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#file-variable"
        },
        {
            "include": "#response-redirect"
        },
        {
            "include": "#query"
        },
        {
            "include": "#headers"
        },
        {
            "include": "#request-line"
        },
        {
            "include": "#response-line"
        },
        {
            "include": "#variable-reference"
        }
    ],
    "repository": {
        "pre-request-script": {
            "begin": "^\\s*(<)\\s*\\{%\\s*$",
            "beginCaptures": {
                "1": {
                    "name": "keyword.control.http"
                }
            },
            "end": "^\\s*%}\\s*$",
            "name": "meta.embedded.block.javascript.http.pre",
            "patterns": [
                {
                    "include": "source.js"
                }
            ]
        },
        "response-handler-script": {
            "begin": "^\\s*(>)\\s*\\{%\\s*$",
            "beginCaptures": {
                "1": {
                    "name": "keyword.control.http"
                }
            },
            "end": "^\\s*%}\\s*$",
            "name": "meta.embedded.block.javascript.http.post",
            "patterns": [
                {
                    "include": "source.js"
                }
            ]
        },
        "request-name-delimiter": {
            "patterns": [
                {
                    "match": "^\\s*(#{3,})(?:\\s+(.+))?\\s*$",
                    "captures": {
                        "1": {
                            "name": "comment.line.sharp.http"
                        },
                        "2": {
                            "name": "entity.name.section.http"
                        }
                    }
                }
            ]
        },
        "metadata": {
            "patterns": [
                {
                    "match": "^\\s*\\#{1,}\\s+((@)[\\w-]+)(?:\\s*(=)?\\s*(.*))?$",
                    "captures": {
                        "1": {
                            "name": "entity.other.attribute-name"
                        },
                        "2": {
                            "name": "punctuation.definition.block.tag.metadata"
                        },
                        "3": {
                            "name": "keyword.operator.assignment.http"
                        },
                        "4": {
                            "name": "string.other.http"
                        }
                    },
                    "name": "comment.line.sharp.http"
                },
                {
                    "match": "^\\s*\\/{2,}\\s+((@)[\\w-]+)(?:\\s*(=)?\\s*(.*))?$",
                    "captures": {
                        "1": {
                            "name": "entity.other.attribute-name"
                        },
                        "2": {
                            "name": "punctuation.definition.block.tag.metadata"
                        },
                        "3": {
                            "name": "keyword.operator.assignment.http"
                        },
                        "4": {
                            "name": "string.other.http"
                        }
                    },
                    "name": "comment.line.double-slash.http"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "match": "^\\s*\\#{1,}.*$",
                    "name": "comment.line.sharp.http"
                },
                {
                    "match": "^\\s*\\/{2,}.*$",
                    "name": "comment.line.double-slash.http"
                }
            ]
        },
        "file-variable": {
            "captures": {
                "1": {
                    "name": "keyword.other.http"
                },
                "2": {
                    "name": "variable.other.http"
                },
                "3": {
                    "patterns": [
                        {
                            "include": "#variable-reference"
                        }
                    ]
                }
            },
            "match": "^\\s*(@)([^\\s=]+)\\s*=\\s*(.*?)\\s*$",
            "name": "http.filevariable"
        },
        "response-redirect": {
            "captures": {
                "1": {
                    "name": "keyword.operator.redirect.http"
                },
                "2": {
                    "name": "string.other.http"
                }
            },
            "match": "^\\s*(>>!?)\\s+(.+?)\\s*$",
            "name": "http.response.redirect"
        },
        "query": {
            "captures": {
                "1": {
                    "name": "keyword.operator.http"
                },
                "2": {
                    "name": "variable.other.http"
                },
                "3": {
                    "patterns": [
                        {
                            "include": "#variable-reference"
                        }
                    ]
                }
            },
            "match": "^\\s*(\\?|&)([^=\\s]+)=(.*)$",
            "name": "http.query"
        },
        "headers": {
            "captures": {
                "1": {
                    "name": "entity.name.tag.http"
                },
                "2": {
                    "name": "keyword.other.http"
                },
                "3": {
                    "patterns": [
                        {
                            "include": "#variable-reference"
                        }
                    ]
                }
            },
            "match": "^([\\w\\-]+)\\s*(\\:)\\s*(.*?)\\s*$",
            "name": "http.headers"
        },
        "request-line": {
            "captures": {
                "1": {
                    "name": "keyword.control.http"
                },
                "2": {
                    "name": "const.language.http"
                },
                "3": {
                    "patterns": [
                        {
                            "include": "#protocol"
                        },
                        {
                            "include": "#variable-reference"
                        }
                    ]
                }
            },
            "match": "(?i)^\\s*(?:(get|post|put|delete|patch|head|options|connect|trace|lock|unlock|propfind|proppatch|copy|move|mkcol|mkcalendar|acl|search|bind|rebind|unbind|link|unlink|merge|purge|report|mkactivity|checkout|msearch|notify|subscribe|unsubscribe)\\s+)?(.+?)(?:\\s+(HTTP\\/\\S+))?$",
            "name": "http.requestline"
        },
        "response-line": {
            "captures": {
                "1": {
                    "patterns": [
                        {
                            "include": "#protocol"
                        }
                    ]
                },
                "2": {
                    "name": "constant.numeric.http"
                },
                "3": {
                    "name": "string.other.http"
                }
            },
            "match": "(?i)^\\s*(HTTP\\/\\S+)\\s([1-5][0-9][0-9])\\s(.*)$",
            "name": "http.responseLine"
        },
        "variable-reference": {
            "patterns": [
                {
                    "match": "\\{\\{[^{}]+\\}\\}",
                    "name": "variable.other.http"
                }
            ]
        },
        "protocol": {
            "patterns": [
                {
                    "captures": {
                        "1": {
                            "name": "keyword.other.http"
                        },
                        "2": {
                            "name": "constant.numeric.http"
                        }
                    },
                    "name": "http.version",
                    "match": "(HTTP)\/(\\d+.\\d+)"
                }
            ]
        }
    }
}
