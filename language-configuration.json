{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["<", ">"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["<", ">"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*((GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE|LOCK|UNLOCK|PROPFIND|PROPPATCH|COPY|MOVE|MKCOL|MKCALENDAR|ACL|SEARCH|BIND|REBIND|UNBIND|LINK|UNLINK|MERGE|PURGE|REPORT|MKACTIVITY|CHECKOUT|MSEARCH|NOTIFY|SUBSCRIBE|UNSUBSCRIBE|curl)\\s+|https?://\\S+|wss?://\\S+)",
            "end": "^#{3,}$"
        }
    }
}